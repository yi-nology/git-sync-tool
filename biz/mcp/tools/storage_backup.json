{
  "name": "storage_backup",
  "description": "Backup repository",
  "parameters": {
    "type": "object",
    "properties": {
      "repo_id": {
        "type": "string",
        "description": "The repository ID"
      },
      "path": {
        "type": "string",
        "description": "The repository path"
      },
      "backup_path": {
        "type": "string",
        "description": "The backup path"
      },
      "include_history": {
        "type": "boolean",
        "description": "Whether to include full history",
        "default": true
      }
    },
    "required": ["path", "backup_path"]
  },
  "returns": {
    "type": "object",
    "properties": {
      "success": {
        "type": "boolean",
        "description": "Whether the backup was successful"
      },
      "message": {
        "type": "string",
        "description": "Operation result message"
      },
      "backup_file": {
        "type": "string",
        "description": "The backup file path"
      }
    }
  }
}